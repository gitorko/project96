meta {
  name: Get All Posts Pagination
  type: graphql
  seq: 2
}

post {
  url: http://localhost:8080/api/graphql
  body: graphql
  auth: none
}

body:graphql {
  query {
    findAllPostsPage (page: 1,size: 10) {
        posts {
            id
            header
            createdBy
        }
      totalElements
      totalPages
      currentPage
      size
    }
  }
}
