meta {
  name: Get All Comments
  type: graphql
  seq: 5
}

post {
  url: http://localhost:8080/api/graphql
  body: graphql
  auth: none
}

body:graphql {
  query {
    findAllComments{
      id
      message
      createdBy
      post {
          id
          header
          createdBy
      }
    }
  }
}
